# Copy this file to deploy/.env and set absolute host paths.
SCENTAI_ADAPTER_HOST_DIR=/absolute/path/to/scentai-gemma-4-12b-it-full-fastmodel-lora/best_lora_adapter
SCENTAI_CHROMA_HOST_DIR=/home/sefasys/Desktop/Perfume-Dataset/chroma_db_bge_m3
SCENTAI_CATALOG_HOST_PATH=/home/sefasys/Desktop/Perfume-Dataset/scentai_catalog.sqlite3
SCENTAI_HF_CACHE_DIR=/home/sefasys/.cache/huggingface
SCENTAI_RUNTIME_UID=1000
SCENTAI_RUNTIME_GID=1000

SCENTAI_API_PORT=8080
SCENTAI_API_KEY=replace-with-a-long-random-secret
SCENTAI_CORS_ORIGINS=http://localhost:3000

# Frozen V4 behavior.
SCENTAI_BASE_MODEL=google/gemma-4-12B-it
SCENTAI_LORA_NAME=scentai
SCENTAI_MAX_MODEL_LEN=4096
SCENTAI_MAX_LORA_RANK=16
# A100 80 GB: 0.65 reserves about 52 GB instead of the notebook's 0.86/~69 GB.
# Raise it when higher concurrent throughput matters more than free VRAM.
SCENTAI_GPU_MEMORY_UTILIZATION=0.65
SCENTAI_RETRIEVAL_MAX_CONCURRENCY=1
SCENTAI_REQUEST_WORKER_THREADS=16

# Required only if the base model cannot be downloaded anonymously.
HF_TOKEN=
